DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/hackathon_db?schema=public"

PORT=3000
NODE_ENV=development

OPENAI_API_KEY="sk-..."

# AWS S3 Configuration
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"
AWS_S3_BUCKET_NAME="your-bucket-name"

# GitHub OAuth Configuration
# OAuth scope used: user:email,repo  (repo scope required for listing repos and PRs)
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# JWT Configuration
JWT_SECRET="your-jwt-secret"

# --- Intent Drift: Claude headless engine (optional overrides) ---
# CLAUDE_MODEL uses the local Claude Code *subscription* login (no API key here).
# GitHub access is via the `gh` CLI (run `gh auth login`, or set GH_TOKEN) — not configured in .env.
# CLAUDE_MODEL="sonnet"          # or "opus" for higher-quality reverse specs
# CLAUDE_MAX_BUDGET_USD="1.0"    # per-run runaway guard
# MAX_DIFF_CHARS="200000"        # soft cap on diff size sent to the model
