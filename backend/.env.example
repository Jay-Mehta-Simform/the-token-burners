DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/hackathon_db?schema=public"

PORT=3000
NODE_ENV=development

OPENAI_API_KEY="sk-..."

# --- Intent Drift: Claude headless engine (optional overrides) ---
